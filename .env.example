# Copy to .env and fill in for your account, then `cp .env.example .env`.
# Precedence: real env var > .env > built-in default. .env is gitignored.

# Name of the profile in ~/.snowflake/connections.toml to use (must have a
# role that can CREATE COMPUTE POOL / ROLE — e.g. ACCOUNTADMIN).
SF_CONNECTION=MY_CONNECTION

# Object names (created if missing). Defaults shown.
SF_DATABASE=ORCHESTRATOR
SF_SCHEMA=CORE
SF_POOL=ORCH_POOL_XS
SF_WAREHOUSE=MY_WAREHOUSE
SF_INSTANCE_FAMILY=CPU_X64_XS

# Workflow-role prefix -> ORCH_LEAD / ORCH_DEVELOPER / ORCH_TESTER /
# ORCH_RUNNER / ORCH_HUMAN_IN_LOOP
SF_ROLE_PREFIX=ORCH

# Image repository + image name.
SF_IMAGE_REPO=IMAGES
SF_IMAGE_NAME=orchestrator_base

# Cortex model (must be available in your account's region).
CORTEX_MODEL=claude-sonnet-4-6

# Path (relative to repo root) to the Programmatic Access Token file.
SF_PAT_FILE=.secrets/pat
